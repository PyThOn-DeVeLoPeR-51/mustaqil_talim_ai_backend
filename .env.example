# Copy this file to .env and fill your local values.
# Example for local PostgreSQL on port 5433:
DATABASE_URL=postgresql+psycopg2://postgres:YOUR_PASSWORD@localhost:5433/mustaqil_talim_db

# Change this in real use. Do not commit your real SECRET_KEY.
SECRET_KEY=change-this-secret-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
